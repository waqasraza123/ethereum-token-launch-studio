{
  "name": "ethereum-token-launch-studio",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --showConfig -p tooling/typescript/node.json > /dev/null && tsc --showConfig -p tooling/typescript/nextjs.json > /dev/null",
    "test": "node --test scripts/workspace-foundation.test.mjs",
    "validate:foundation": "node scripts/verify-workspace-foundation.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.25.1",
    "@types/node": "22.15.3",
    "eslint": "9.25.1",
    "globals": "16.0.0",
    "prettier": "3.5.3",
    "turbo": "2.5.3",
    "typescript": "5.8.3"
  }
}
