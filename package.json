{
  "name": "ethereum-token-launch-studio",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "build": "turbo run build",
    "dev:web": "turbo run dev --filter=@token-launch-studio/web",
    "dev:worker": "turbo run dev --filter=@token-launch-studio/worker",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0 && turbo run lint",
    "typecheck": "tsc --showConfig -p tooling/typescript/node.json > /dev/null && tsc --showConfig -p tooling/typescript/nextjs.json > /dev/null && turbo run typecheck",
    "test": "node --test scripts/workspace-foundation.test.mjs && turbo run test",
    "validate:foundation": "node scripts/verify-workspace-foundation.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.25.1",
    "@types/node": "25.5.0",
    "eslint": "9.25.1",
    "eslint-config-next": "16.2.1",
    "globals": "16.0.0",
    "prettier": "3.5.3",
    "turbo": "2.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.57.2"
  }
}
